{
  "manifest_version": 3,
  "name": "Alloist Consent",
  "version": "0.1.0",
  "description": "Real-time AI action consent for Alloist",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8001/*", "ws://localhost:8001/*", "http://127.0.0.1:8001/*", "ws://127.0.0.1:8001/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Alloist Consent"
  },
  "options_ui": {
    "page": "popup/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
