{
  "name": "alloist-consent-extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build:popup && npm run build:scripts && npm run copy:manifest",
    "build:popup": "vite build --config vite.popup.config.ts",
    "build:scripts": "vite build --config vite.background.config.ts && vite build --config vite.content.config.ts",
    "copy:manifest": "cp manifest.json dist/"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
